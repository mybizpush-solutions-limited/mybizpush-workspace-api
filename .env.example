# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (the UI dev server, etc.)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Auth ----
# Only emails ending in this domain may sign up / log in.
ALLOWED_EMAIL_DOMAIN=mybizpush.com
# Use long, random strings in production (e.g. `openssl rand -hex 48`).
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Postgres ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mybizpush_dev_space

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Cloudinary (image/video uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=mybizpush-dev-space

# ---- Resend (transactional email) ----
RESEND_API_KEY=
EMAIL_FROM="MyBizPush Workspace<no-reply@mybizpush.com>"

# ---- OpenRouter (AI assistant) ----
OPENROUTER_API_KEY=
# Any OpenRouter model slug (see https://openrouter.ai/models)
OPENROUTER_MODEL=openai/gpt-oss-20b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- App URL (used in emails, e.g. password-reset links) ----
APP_URL=http://localhost:3000

# ---- GitHub App (org-wide integration) ----
GITHUB_API_URL=https://api.github.com
# Org the App is installed on; also the org whose membership is verified on
# "Connect GitHub" (leave empty to skip the membership check).
GITHUB_ORG=
# Secret you set on the App's webhook — verifies inbound payloads (X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET=
# From the App's settings page. GITHUB_APP_PRIVATE_KEY accepts any of:
#   • an absolute path to the .pem file (easiest for local dev), e.g.
#     GITHUB_APP_PRIVATE_KEY=/Users/you/my-app.private-key.pem
#   • a base64 of the whole .pem (best for containers):  base64 -i key.pem | tr -d '\n'
#   • the PEM inline with literal "\n" between lines.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Optional: pin the installation id (Org → Settings → third-party Access →
# GitHub Apps → Configure → the number at the end of the URL). Auto-discovered
# from GITHUB_ORG when left empty — you can leave this blank.
GITHUB_APP_INSTALLATION_ID=

# ---- GitHub user authorization (the same App's client credentials) ----
# From the App's settings page; the "Callback URL" must match GITHUB_OAUTH_REDIRECT_URI.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/github/callback
GITHUB_OAUTH_BASE_URL=https://github.com/login/oauth

# ---- Digest scheduler ----
ENABLE_DIGEST_SCHEDULER=true
DIGEST_DAILY_CRON=0 8 * * *
DIGEST_WEEKLY_CRON=0 8 * * 1

# ---- Google OAuth (Calendar + Meet) ----
# Add GOOGLE_REDIRECT_URI to your OAuth client's Authorized redirect URIs,
# and APP_URL's origin to the Authorized JavaScript origins.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/google/callback
